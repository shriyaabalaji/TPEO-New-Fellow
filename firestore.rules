rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEV-RESET RULES:
    // - Any signed-in user can read and write any document.
    // - Demo / unsigned users cannot write.
    // This is intentionally permissive to get the app working again.
    // When you're ready, we can lock this back down.

    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}